    {
      "bossNo": 2,
      "dominantTags": [
        "line_skill_lane"
      ],
      "clueCount": 1,
      "sampleClues": [
        {
          "topicId": "60038404a4f7ad546d152df9",
          "normalizedTag": "line_skill_lane",
          "clueText": "2号BOSS 暗影猎手 俗称小Y 自带特效攻击会吧武器丢出去直线飞行再回来 期间伤害中招的英雄 打小Y要求就有点高了  需要走位  还需要队友别乱走 不然很容易把队友都害死 仇恨目标是你的时候一定不要慌 站在原地打 等队友奶或者牺牲自己让队友尽快输出 毕竟 死一个人比团灭要好得多  注意 期间如果在蛇棒范围内 记得把BOSS拉出蛇棒范围再锤他  先弄死BOSS 再杀蛇棒好的多 毕竟蛇棒属于守卫 不吃很多技能 但是如果有守望者的话 他的刀阵旋风可以对守卫造成伤害"
        }
      ]
    },
    {
      "bossNo": 3,
      "dominantTags": [
        "movement_check"
      ],
      "clueCount": 1,
      "sampleClues": [
        {
          "topicId": "60038404a4f7ad546d152df9",
          "normalizedTag": "movement_check",
          "clueText": "3号BOSS 大萨满 阴间BOSS一枚  老恶心了  减速 逼走位  不小心就给给了     建议先清小兵再锤BOSS  半血之后放技能很频繁 攻击自带AOE  小兵的每一下普攻都是闪电链"
        }
      ]
    },
    {
      "bossNo": 4,
      "dominantTags": [
        "line_skill_lane"
      ],
      "clueCount": 1,
      "sampleClues": [
        {
          "topicId": "60038404a4f7ad546d152df9",
          "normalizedTag": "line_skill_lane",
          "clueText": "4号BOSS 地穴领主 俗称小强 清好小怪 走走位算是很好打了  注意 他钻地后是带反伤的哦 攻击自带AOE 对近战不是很友好 小怪自带技能蛛网 直线飞行 捆住第一个挨到的英雄"
        }
      ]
    },
    {
      "bossNo": 5,
      "dominantTags": [
        "line_skill_lane"
      ],
      "clueCount": 1,
      "sampleClues": [
        {
          "topicId": "60038404a4f7ad546d152df9",
          "normalizedTag": "line_skill_lane",
          "clueText": "5号BOSS  月之女祭司 俗称白虎 攻击自带直线范围伤害 而且射程很远并且穿透  不是很难 杀小怪 再杀BOSS  小怪也和BOSS攻击同理"
        }
      ]
    },
